    <style>
        body { font-family: 'Calibri', 'Segoe UI', Arial, sans-serif; padding: 20px; line-height: 1.5; color: #333333; }
        h1 { color: #2C3E50; border-bottom: 2px solid #34495E; padding-bottom: 5px; font-size: 24pt;}
        h2 { color: #2980B9; margin-top: 20px; font-size: 18pt;}
        h3 { color: #16A085; font-size: 14pt;}
        table { border-collapse: collapse; width: 100%; margin-top: 10px; margin-bottom: 20px;}
        th, td { border: 1px solid #DDDDDD; padding: 8px; text-align: left; font-size: 11pt;}
        th { background-color: #F2F2F2; font-weight: bold;}
        code { font-family: Consolas, monospace; background-color: #F8F9FA; padding: 2px 4px; border-radius: 3px; font-size: 10.5pt;}
        pre { font-family: Consolas, monospace; background-color: #F8F9FA; color: #333333; padding: 10px; border: 1px solid #DDDDDD; border-radius: 5px; font-size: 10pt; white-space: pre-wrap;}
    </style>
